{
  "name": "Kronenchronik",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/postgres:1": {
      "version": "16",
      "postgresPassword": "postgres"
    }
  },
  "forwardPorts": [5173, 3001],
  "portsAttributes": {
    "5173": {
      "label": "🎮 Kronenchronik spielen",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    },
    "3001": {
      "label": "API (Backend)",
      "visibility": "public"
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "npm run dev",
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode", "prisma.prisma"]
    }
  },
  "remoteEnv": {
    "DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/kronenchronik?schema=public"
  }
}
